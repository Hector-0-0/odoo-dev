<odoo>

    <!--VISTAS-->

    <record id="view_list_libro_reclamaciones" model="ir.ui.view">
        <field name="name">view.list.libro.reclamaciones</field>
        <field name="model">libro.reclamaciones</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state"/>
                <field name="priority" widget="priority"/>
                <field name="company_id"/>
                <field name="claim_user_id"/>                
            </list>
        </field>
    </record>

    <record id="view_form_libro_reclamaciones" model="ir.ui.view">
        <field name="name">view.form.libro.reclamaciones</field>
        <field name="model">libro.reclamaciones</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_in_process" string="En Progreso" 
                            type="object" class="btn-primary" 
                            invisible="state != 'new'"/>
                    <button name="action_claim_cancel" string="Cancelar" 
                            type="object" class="btn-danger" groups="l10n_pe_libro_reclamaciones.res_groups_libro_reclamaciones_admin" 
                            invisible="state not in ['in_process']"/>
                    <button name="action_revert" string="Revertir Reclamo" 
                            type="object" class="btn-warning" groups="l10n_pe_libro_reclamaciones.res_groups_libro_reclamaciones_admin" 
                            invisible="state != 'cancel'"/>
                    <button name="action_claim_resolved" string="Resolver Reclamo" 
                            type="object" class="btn-success" groups="l10n_pe_libro_reclamaciones.res_groups_libro_reclamaciones_admin" 
                            invisible="state != 'in_process'"/>+
                    <field name="state" string="Estado" widget="statusbar"/>
                </header>
                <sheet>
                    <h2>
                        <field name="name" readonly="1"/>
                    </h2>
                    <group>
                        <field name="priority" widget="priority"/>
                        <field name="company_id" readonly="1" force_save="1" options="{'no_open':1}"/>
                        <field name="claim_user_id" options="{'no_open':1,'no_create':1,'no_creat_edit':1}"/>
                    </group>
                    <group string="DATOS DEL CONSUMIDOR O USUARIO">
                        <group>
                            <field name="consumer_type" widget="radio" options="{'horizontal': 1}"/>
                            <field name="consumer_company_name" invisible="consumer_type != 'company'"
                                                                required="consumer_type == 'company'"
                                                                readonly="state!='new'"/>
                            <field name="consumer_company_document" invisible="consumer_type != 'company'"
                                                                required="consumer_type == 'company'"
                                                                readonly="state!='new'"/>
                            <field name="consumer_name" invisible="consumer_type != 'individual'"
                                                                required="consumer_type == 'individual'"
                                                                readonly="state!='new'"/>
                            <field name="consumer_lastname" invisible="consumer_type != 'individual'"
                                                                required="consumer_type == 'individual'"
                                                                readonly="state!='new'"/>
                            <field name="consume_email" readonly="state!='new'"/>
                            <field name="consumer_document_type" widget="radio" options="{'horizontal': 1}"/>
                            <field name="consumer_document"/>
                        </group>
                        <group>
                            <field name="consumer_phone" placeholder="+51 999999999"/>
                            <field name="consumer_address" placeholder="Avenida, Calle ..."/>
                            <field name="consumer_country_id"
                                        options="{'no_open':1,'no_create':1,'no_creat_edit':1}"/>
                            <field name="consumer_state_id" string="Departamento" 
                                        domain="[('country_id', '=', consumer_country_id)]"
                                        options="{'no_open':1,'no_create':1,'no_creat_edit':1}"/>
                            <field name="consumer_province_id" string="Provincia" 
                                        domain="[('state_id', '=', consumer_state_id)]"
                                        options="{'no_open':1,'no_create':1,'no_creat_edit':1}"/>
                            <field name="consumer_district_id" string="Distrito" domain="[('city_id', '=', consumer_province_id)]"
                                        options="{'no_open':1,'no_create':1,'no_creat_edit':1}"/>
                            <field name="consumer_younger" invisible="consumer_type != 'individual'" widget="boolean_toggle"/>
                        </group>
                        <group string="DATOS DEL REPRESENTANTE LEGAL" invisible="consumer_type != 'individual' or not consumer_younger">
                            <field name="consumer_younger_parent_name" invisible="consumer_type != 'individual' or not consumer_younger"/>
                            <field name="consumer_younger_parent_lastname" invisible="consumer_type != 'individual' or not consumer_younger"/>
                            <field name="consumer_younger_parent_document_type" widget="radio" options="{'horizontal': 1}" invisible="consumer_type != 'individual' or not consumer_younger"/>
                            <field name="consumer_younger_parent_document" invisible="consumer_type != 'individual' or not consumer_younger"/>
                        </group>
                    </group>
                    <group string="DATOS DEL BIEN CONTRATADO">
                        <field name="product_type" widget="radio" options="{'horizontal': 1}"/>
                        <field name="product_name"/>
                        <field name="order_name"/>
                        <field name="product_id"/>
                        <field name="date_order"/>
                    </group>
                    <group string="DETALLE DEL RECLAMO O QUEJA">
                        <field name="claim_type" widget="radio" options="{'horizontal': 1}"/>
                        <field name="claim_detail"/>
                        <field name="claim_request"/>
                        <field name="claim_amount"/>
                        <field name="currency_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--ACCION DE VENTANA-->

    <record id="action_view_libro_reclamaciones" model="ir.actions.act_window">
        <field name="name">Registros</field>
        <field name="res_model">libro.reclamaciones</field>
        <field name="view_mode">list,form</field>
    </record>


    <!--MENUS-->

    <menuitem id="menu_main_libro_reclamaciones" 
                name="Libro de Reclamaciones" 
                sequence="21"/>

    <menuitem id="menu_registro_reclamos" 
                name="Registros"
                parent="menu_main_libro_reclamaciones" 
                action="action_view_libro_reclamaciones" />

</odoo>