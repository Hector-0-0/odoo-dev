<odoo>
    <record id="res_config_settings_libro_reclamaciones" model="ir.ui.view">
        <field name="name">res.config.settings.libro.reclamaciones/view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="priority" eval="60"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Libro de Reclamaciones"
                    string = "Libro de Reclamaciones"
                    name="libro_reclamaciones"
                    logo="/l10n_pe_libro_reclamaciones/static/description/icon.png">
                    <setting string="Plazo de atencion" help="Plazo de atencion de reclamo en dias">
                    <div class="content-group">
                        <div class="rowmt16">
                            <label name="claim_attention_period" for="claim_attention_period"/>
                            <field name="claim_attention_period"/>
                        </div>
                    </div>
                    </setting>
                    <setting string="Responsable de reclamos y quejas" help="Usuario responsable de la gestion de reclamos y quejas">
                    <div class="content-group">
                        <div class="rowmt16">
                            <label class="col-lg-3 o_light_label" string="Responsable" for="claim_user_id"/>
                            <field name="claim_user_id"/>
                        </div>
                    </div>
                    </setting>
                </app>
            </xpath>
        </field>
    </record>
</odoo>