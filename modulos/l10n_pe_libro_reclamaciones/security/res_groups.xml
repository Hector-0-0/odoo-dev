<odoo>
    <record id="category_libro_reclamaciones_app" model="ir.module.category">
        <field name="name">Libro de Reclamaciones</field>
    </record>    

    <record id="category_libro_reclamaciones" model="ir.module.category">
        <field name="name">Libro de Reclamaciones</field>
        <field name="parent_id" ref="category_libro_reclamaciones_app"/>
    </record>

    <record id="res_groups_libro_reclamaciones_user" model="res.groups">
        <field name="name">Usuario</field>
        <field name="category_id" ref="category_libro_reclamaciones"/>
    </record>

    <record id="res_groups_libro_reclamaciones_admin" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="category_libro_reclamaciones"/>
        <field name="implied_ids" eval="[(4, ref('res_groups_libro_reclamaciones_user'))]"/>
    </record>  

</odoo>